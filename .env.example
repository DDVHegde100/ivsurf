# Alpaca Markets API (optional — enables 1-min + premarket bars)
# Sign up: https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# paper or live
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# SQLite database path (optional, defaults to data/ivsurf.db)
IVSURF_DB_PATH=data/ivsurf.db

# API key (optional — when set, /scan /predict /signals require X-API-Key header)
IVSURF_API_KEY=

# PostgreSQL (optional — enables shared storage for multi-instance API deployments)
# IVSURF_DATABASE_URL=postgresql://user:pass@host:5432/ivsurf
IVSURF_DATABASE_URL=

# Local data directory for Parquet exports (defaults to data/)
IVSURF_DATA_DIR=data

# Trained opening ML ranker path (default: data/models/opening_ranker.joblib)
IVSURF_MODEL_PATH=data/models/opening_ranker.joblib

# Webhook alerts (optional — Slack/Discord notifications for high-score hits)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
IVSURF_ALERT_MIN_SCORE=50
