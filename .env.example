# Alpaca Markets API (optional — enables 1-min + premarket bars)
# Sign up: https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# paper or live
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# SQLite database path (optional, defaults to data/ivsurf.db)
IVSURF_DB_PATH=data/ivsurf.db

# API key (optional — when set, /scan /predict /signals require X-API-Key header)
IVSURF_API_KEY=
